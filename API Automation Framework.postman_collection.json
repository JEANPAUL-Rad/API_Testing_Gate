  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test(\"Access token is present and valid\", function () {",
                  "    pm.expect(json).to.have.property(\"accessToken\");",
                  "    pm.expect(json.accessToken).to.be.a(\"string\").and.not.be.empty;",
                  "});",
                  "",
                  "if (json.accessToken) {",
                  "    pm.environment.set(\"accessToken\", json.accessToken);",
                  "}",
                  "",
                  "pm.test(\"Checks if optional fields are of the correct types\", function () {",
                  "    if (json.expiresIn !== undefined) {",
                  "        pm.expect(json.expiresIn).to.be.a(\"number\");",
                  "    }",
                  "    if (json.user && json.user.id !== undefined) {",
                  "        pm.expect(json.user.id).to.be.a(\"number\");",
                  "    }",
                  "});",
                  "",
                  "pm.test(\"Response time is within 200ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.at.most(200);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"{{username}}\",\"password\":\"{{password}}\"}\r\n\r\n//{\"username\":\"emilys\",\"password\":\"emilyspass\"}\r\n",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/user/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "login"
              ]
            },
            "description": "Generated from cURL: curl --location --request POST '{{baseUrl}}/user/login' --header 'Content-Type: application/json' --data-raw '{\"username\":\"kminchelle\",\"password\":\"0lelplR\"}'"
          },
          "response": []
        }
      ]
    },
    {
      "name": "User Management",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response is JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "const jsonData = pm.response.json();",
                  "",
                  "pm.test(\"User response has required fields with correct types\", function () {",
                  "    pm.expect(jsonData).to.have.property(\"id\");",
                  "    pm.expect(jsonData.id).to.be.a(\"number\");",
                  "",
                  "    pm.expect(jsonData).to.have.property(\"firstName\");",
                  "    pm.expect(jsonData.firstName).to.be.a(\"string\");",
                  "",
                  "    pm.expect(jsonData).to.have.property(\"lastName\");",
                  "    pm.expect(jsonData.lastName).to.be.a(\"string\");",
                  "",
                  "    pm.expect(jsonData).to.have.property(\"age\");",
                  "    pm.expect([\"number\", \"string\"]).to.include(typeof jsonData.age);",
                  "",
                  "    pm.expect(jsonData).to.have.property(\"email\");",
                  "    pm.expect(jsonData.email).to.be.a(\"string\");",
                  "});",
                  "",
                  "if (typeof jsonData.id === \"number\") {",
                  "    pm.environment.set(\"userId\", jsonData.id);",
                  "}",
                  "",
                  "pm.test(\"Response time is within 200ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.at.most(200);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\":\"{{$randomFirstName}}\",\"lastName\":\"{{$randomLastName}}\",\"age\":\"{{$randomInt}}\",\"email\":\"{{$randomEmail}}\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/users/add",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "add"
              ]
            },
            "description": "Generated from cURL: curl --location --request POST '{{baseUrl}}/users/add' --header 'Content-Type: application/json' --data-raw '{\"firstName\":\"John\",\"lastName\":\"Doe\",\"age\":30,\"email\":\"john.doe@example.com\"}'"
          },
          "response": []
        },
        {
          "name": "GET User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test(\"User profile has required fields with correct types\", function () {",
                  "    pm.expect(json).to.be.an(\"object\");",
                  "",
                  "    pm.expect(json).to.have.property(\"id\");",
                  "    pm.expect(json.id).to.be.a(\"number\");",
                  "",
                  "    pm.expect(json).to.have.property(\"firstName\");",
                  "    pm.expect(json.firstName).to.be.a(\"string\");",
                  "",
                  "    pm.expect(json).to.have.property(\"lastName\");",
                  "    pm.expect(json.lastName).to.be.a(\"string\");",
                  "",
                  "    pm.expect(json).to.have.property(\"age\");",
                  "    pm.expect(json.age).to.be.a(\"number\");",
                  "",
                  "    if (json.email !== undefined) {",
                  "        pm.expect(json.email === null || typeof json.email === \"string\").to.be.true;",
                  "    }",
                  "",
                  "    pm.expect(json).to.have.property(\"username\");",
                  "    pm.expect(json.username).to.be.a(\"string\");",
                  "",
                  "    if (json.gender !== undefined) {",
                  "        pm.expect(json.gender).to.be.a(\"string\");",
                  "    }",
                  "});",
                  "",
                  "pm.test(\"Response time is within 200ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.at.most(200);",
                  "});",
                  "",
                  "pm.test(\"Environment userId is numeric if set\", function () {",
                  "    const envUserId = pm.environment.get(\"userId\");",
                  "    if (envUserId) {",
                  "        pm.expect(Number.isNaN(Number(envUserId))).to.eql(false);",
                  "    }",
                  "});",
                  "",
                  "pm.test(\"Response matches user profile schema\", function () {",
                  "   const schema = {",
                  "    type: \"object\",",
                  "    additionalProperties: true,",
                  "    required: [\"id\", \"firstName\", \"lastName\", \"age\", \"email\", \"phone\", \"username\"],",
                  "    properties: {",
                  "        id: { type: \"number\" },",
                  "        firstName: { type: \"string\" },",
                  "        lastName: { type: \"string\" },",
                  "        age: { type: \"number\" },",
                  "        email: { type: \"string\" },",
                  "        phone: { type: \"string\" },",
                  "        username: { type: \"string\" },",
                  "        address: { type: \"object\", additionalProperties: true },",
                  "        isDeleted: { type: \"boolean\" }",
                  "    }",
                  "};",
                  "    pm.response.to.have.jsonSchema(schema);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
