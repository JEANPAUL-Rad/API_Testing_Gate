        {
          "name": "GET User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "pm.test(\"User profile has core fields with correct types\", function () {",
                  "    const json = pm.response.json();",
                  "",
                  "    pm.expect(json).to.be.an(\"object\");",
                  "",
                  "    pm.expect(json).to.have.property(\"id\");",
                  "    pm.expect(json.id).to.be.a(\"number\");",
                  "",
                  "    pm.expect(json).to.have.property(\"firstName\");",
                  "    pm.expect(json.firstName).to.be.a(\"string\");",
                  "",
                  "    pm.expect(json).to.have.property(\"lastName\");",
                  "    pm.expect(json.lastName).to.be.a(\"string\");",
                  "",
                  "    // DummyJSON uses a number for age",
                  "    pm.expect(json).to.have.property(\"age\");",
                  "    pm.expect(json.age).to.be.a(\"number\");",
                  "",
                  "    // email may be missing or null in some APIs; allow string/null/undefined",
                  "    if (Object.prototype.hasOwnProperty.call(json, \"email\")) {",
                  "        pm.expect(json.email === null || typeof json.email === \"string\").to.be.true;",
                  "    }",
                  "",
                  "    pm.expect(json).to.have.property(\"username\");",
                  "    pm.expect(json.username).to.be.a(\"string\");",
                  "",
                  "    // gender may exist depending on API version; if present, validate type",
                  "    if (Object.prototype.hasOwnProperty.call(json, \"gender\")) {",
                  "        pm.expect(json.gender).to.be.a(\"string\");",
                  "    }",
                  "});",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "})",
                  "",
                  "pm.test('Response is JSON', function () {",
                  "    pm.response.to.be.json;",
                  "})",
                  "",
                  "pm.test('Latency <= 200ms (soft)', function () {",
                  "    const threshold = 200;",
                  "    const rt = pm.response.responseTime;",
                  "    if (rt > threshold) {",
                  "        const msg = `WARN: ${ pm.info.requestName } latency ${ rt }ms > ${ threshold }ms`;",
                  "        pm.environment.set('latencyWarning', msg);",
                  "    }",
                  "    pm.expect(true).to.be.true;",
                  "})",
                  "",
                  "pm.test('If environment userId is set, it is numeric', function () {",
                  "    const envUserId = pm.environment.get('userId');",
                  "    if (envUserId !== undefined && envUserId !== null && envUserId !== '') {",
                  "        const n = Number(envUserId);",
                  "        pm.expect(Number.isNaN(n)).to.eql(false);",
                  "    }",
                  "})",
                  "",
                  "pm.test('Response matches user profile schema (core fields)', function () {",
                  "    const schema = {",
                  "        type: 'object',",
                  "        additionalProperties: true,",
                  "        required: [",
                  "            'id',",
                  "            'firstName',",
                  "            'lastName',",
                  "            'age',",
                  "            'email',",
                  "            'phone',",
                  "            'username'",
                  "        ],",
                  "        properties: {",
                  "            id: { type: 'number' },",
                  "            firstName: { type: 'string' },",
                  "            lastName: { type: 'string' },",
                  "            age: { type: 'number' },",
                  "            email: { type: 'string' },",
                  "            phone: { type: 'string' },",
                  "            username: { type: 'string' },",
                  "            address: {",
                  "                type: 'object',",
                  "                additionalProperties: true",
                  "            },",
                  "            isDeleted: { type: 'boolean' }",
                  "        }",
                  "    };",
                  "    pm.response.to.have.jsonSchema(schema);",
                  "})"
                ]
              }
            }
