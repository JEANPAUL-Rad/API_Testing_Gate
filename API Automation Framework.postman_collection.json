        {
          "name": "Update User (PUT id=1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test(\"Returned fields match sent values\", function () {",
                  "    const sent = { firstName: \"Janet\", age: 31 };",
                  "",
                  "    pm.expect(json).to.be.an(\"object\");",
                  "    pm.expect(json).to.have.property(\"id\");",
                  "    pm.expect(json.id).to.be.a(\"number\");",
                  "",
                  "    pm.expect(json).to.have.property(\"firstName\");",
                  "    pm.expect(json.firstName).to.eql(sent.firstName);",
                  "",
                  "    pm.expect(json).to.have.property(\"age\");",
                  "    pm.expect(json.age).to.eql(sent.age);",
                  "});",
                  "",
                  "pm.test(\"Updated user has id and core fields with expected types\", function () {",
                  "    pm.expect(json).to.be.an(\"object\");",
                  "    pm.expect(json).to.have.property(\"id\");",
                  "    pm.expect(json.id).to.be.a(\"number\");",
                  "",
                  "    if (json.firstName !== undefined) {",
                  "        pm.expect(json.firstName).to.be.a(\"string\");",
                  "    }",
                  "    if (json.lastName !== undefined) {",
                  "        pm.expect(json.lastName).to.be.a(\"string\");",
                  "    }",
                  "    if (json.age !== undefined) {",
                  "        pm.expect([\"number\", \"string\"]).to.include(typeof json.age);",
                  "    }",
                  "    if (json.email !== undefined) {",
                  "        pm.expect(json.email).to.be.a(\"string\");",
                  "    }",
                  "});",
                  "",
                  "pm.test(\"Response time is within 200ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.at.most(200);",
                  "});",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
