        {
          "name": "GET User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test(\"User profile has required fields with correct types\", function () {",
                  "    pm.expect(json).to.be.an(\"object\");",
                  "",
                  "    pm.expect(json).to.have.property(\"id\");",
                  "    pm.expect(json.id).to.be.a(\"number\");",
                  "",
                  "    pm.expect(json).to.have.property(\"firstName\");",
                  "    pm.expect(json.firstName).to.be.a(\"string\");",
                  "",
                  "    pm.expect(json).to.have.property(\"lastName\");",
                  "    pm.expect(json.lastName).to.be.a(\"string\");",
                  "",
                  "    pm.expect(json).to.have.property(\"age\");",
                  "    pm.expect(json.age).to.be.a(\"number\");",
                  "",
                  "    if (json.email !== undefined) {",
                  "        pm.expect(json.email === null || typeof json.email === \"string\").to.be.true;",
                  "    }",
                  "",
                  "    pm.expect(json).to.have.property(\"username\");",
                  "    pm.expect(json.username).to.be.a(\"string\");",
                  "",
                  "    if (json.gender !== undefined) {",
                  "        pm.expect(json.gender).to.be.a(\"string\");",
                  "    }",
                  "});",
                  "",
                  "pm.test(\"Latency <= 200ms (soft)\", function () {",
                  "    const threshold = 200;",
                  "    const rt = pm.response.responseTime;",
                  "    if (rt > threshold) {",
                  "        pm.environment.set(\"latencyWarning\", `WARN: ${pm.info.requestName} latency ${rt}ms > ${threshold}ms`);",
                  "    }",
                  "    pm.expect(true).to.be.true;",
                  "});",
                  "pm.test(\"Environment userId is numeric if set\", function () {",
                  "    const envUserId = pm.environment.get(\"userId\");",
                  "    if (envUserId) {",
                  "        pm.expect(Number.isNaN(Number(envUserId))).to.eql(false);",
                  "    }",
                  "});",
                  "",
                  "pm.test(\"Response matches user profile schema\", function () {",
                  "    const schema = {",
                  "        type: \"object\",",
                  "        additionalProperties: true,",
                  "        required: [\"id\", \"firstName\", \"lastName\", \"age\", \"email\", \"phone\", \"username\"],",
                  "        properties: {",
                  "            id: { type: \"number\" },",
                  "            firstName: { type: \"string\" },",
                  "            lastName: { type: \"string\" },",
                  "            age: { type: \"number\" },",
                  "            email: { type: \"string\" },",
                  "            phone: { type: \"string\" },",
                  "            username: { type: \"string\" },",
                  "            address: { type: \"object\", additionalProperties: true },",
                  "            isDeleted: { type: \"boolean\" }",
                  "        }",
                  "    };",
                  "    pm.response.to.have.jsonSchema(schema);",
                  "});",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
