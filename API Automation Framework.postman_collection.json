      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is JSON', function () {",
                  "  pm.response.to.be.json;",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Token is present', function () {",
                  "  pm.expect(json).to.have.property('accessToken');",
                  "  pm.expect(json.accessToken).to.be.a('string').and.not.be.empty;",
                  "});",
                  "",
                  "if (json && json.accessToken) {",
                  "  pm.environment.set('accessToken', json.accessToken);",
                  "}",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "})",
                  "",
                  "pm.test('Response is JSON', function () {",
                  "    pm.response.to.be.json;",
                  "})",
                  "",
                  "pm.test('Latency <= 200ms (soft)', function () {",
                  "    const threshold = 200;",
                  "    const rt = pm.response.responseTime;",
                  "    if (rt > threshold) {",
                  "        const msg = `WARN: ${ pm.info.requestName } latency ${ rt }ms > ${ threshold }ms`;",
                  "        pm.environment.set('latencyWarning', msg);",
                  "    }",
                  "    pm.expect(true).to.be.true;",
                  "})",
                  "",
                  "pm.test('Access token is present and is a string', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('object');",
                  "    pm.expect(jsonData).to.have.property('accessToken');",
                  "    pm.expect(jsonData.accessToken).to.be.a('string').and.to.have.length.greaterThan(0);",
                  "})",
                  "",
                  "pm.test('Optional fields: expiresIn is number, user.id is number (if present)', function () {",
                  "    const jsonData = pm.response.json();",
                  "    if (Object.prototype.hasOwnProperty.call(jsonData, 'expiresIn')) {",
                  "        pm.expect(jsonData.expiresIn).to.be.a('number');",
                  "    }",
                  "    if (jsonData.user && typeof jsonData.user === 'object') {",
                  "        if (Object.prototype.hasOwnProperty.call(jsonData.user, 'id')) {",
                  "            pm.expect(jsonData.user.id).to.be.a('number');",
                  "        }",
                  "    }",
                  "})",
                  "",
                  "pm.test('Set accessToken into environment (if present)', function () {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData && typeof jsonData.accessToken === 'string' && jsonData.accessToken.length > 0) {",
                  "        pm.environment.set('accessToken', jsonData.accessToken);",
                  "    }",
                  "    pm.expect(true).to.be.true;",
                  "})"
                ]
              }
            }
          ],
